# Nero CAN auto-activation settings
# Keep CAN_PORT consistent with web_control/config.json -> robot.can_port
# Recommended: use a dedicated alias like nero_can for the USB-CAN adapter.
CAN_PORT=nero_can
BITRATE=1000000
RETRY_INTERVAL=2
MAX_WAIT_SECONDS=90

# Optional: set your USB bus-info if you have more than one CAN adapter.
# Example: USB_ADDRESS=1-2.2:1.0
USB_ADDRESS=1-2.2:1.0
